# 可选：指定外部多提供商配置文件
# 不填时，会自动尝试读取：
# ./config/providers.local.json
EXTERNAL_PROVIDER_CONFIG=

# 默认资料包
EX_SKILL_DEFAULT_SLUG=example_xiaoming

# 文本聊天主模型
# 不填时，会自动优先使用 SiliconFlow (硅基流动) 的 deepseek-ai/DeepSeek-V3.2
TEXT_PROVIDER_NAME=
TEXT_API_BASE_URL=
TEXT_API_KEY=
TEXT_MODEL_NAME=
TEXT_TIMEOUT=60
TEXT_TEMPERATURE=0.8

# 自动补全器模型
# 不填时，会自动优先使用 DeepSeek Official 的 deepseek-chat
ENRICH_PROVIDER_NAME=
ENRICH_API_BASE_URL=
ENRICH_API_KEY=
ENRICH_MODEL_NAME=
ENRICH_TIMEOUT=120
ENRICH_TEMPERATURE=0.2

# 语音提供商
# 支持：
# - siliconflow_clone：自动上传本地语音样本，生成自定义声线
# - openai_compatible：普通 TTS
# - custom_http：对接你自己的语音后端
# - none：关闭语音
TTS_PROVIDER=siliconflow_clone
TTS_PROVIDER_NAME=
TTS_API_BASE_URL=
TTS_API_KEY=
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:anna
TTS_TIMEOUT=90
TTS_CUSTOM_ENDPOINT=

# 本地语音样本目录
VOICE_REFERENCE_DIR=./data/voice_samples
